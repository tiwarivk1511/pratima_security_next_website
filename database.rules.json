{
  "rules": {
    
    "contact_submissions": {
      ".read": "auth != null",
      ".write": "true",
      "$submission_id": {
        ".validate": "newData.hasChildren(['name', 'email', 'message', 'createdAt', 'status'])"
      }
    },
    
    
    "mission_requests": {
      ".read": "auth != null",
      ".write": "true",
      "$request_id": {
        ".validate": "newData.hasChildren(['fullName', 'email', 'phone', 'address', 'service', 'surveyDate', 'createdAt', 'status'])"
      }
    },

    
    "facility_enquiries": {
      ".read": "auth != null",
      ".write": "true",
      "$enquiry_id": {
        ".validate": "newData.hasChildren(['fullName', 'email', 'phone', 'address', 'service', 'requiredDate', 'timestamp'])"
      }
    },

   
    "subscriptions": {
      ".read": "auth != null", 
      ".write": "true",
      "$sub_id": {
        ".validate": "newData.hasChildren(['userName', 'userEmail', 'subscribedAt', 'source'])"
      }
    },

    
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}